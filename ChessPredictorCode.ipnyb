    {
      "cell_type": "code",
      "source": [
        "# 8. VISUALIZATION - PREDICTED WIN PROBABILITY BY ELO DIFF\n",
        "\n",
        "elo_diffs = np.arange(-600, 601, 50)\n",
        "white_win_probs = []\n",
        "black_win_probs = []\n",
        "draw_probs = []\n",
        "\n",
        "base_elo = 1500\n",
        "for diff in elo_diffs:\n",
        "    w = base_elo + max(0, diff)\n",
        "    b = base_elo - min(0, diff)\n",
        "    r = predict_outcome(w, b, \"King's Pawn Game\")\n",
        "    white_win_probs.append(r[\"White wins\"])\n",
        "    black_win_probs.append(r[\"Black wins\"])\n",
        "    draw_probs.append(r[\"Draw\"])\n",
        "\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.plot(elo_diffs, white_win_probs, label=\"White Wins\", color=\"#42A5F5\", linewidth=2)\n",
        "plt.plot(elo_diffs, black_win_probs, label=\"Black Wins\", color=\"#EF5350\", linewidth=2)\n",
        "plt.plot(elo_diffs, draw_probs, label=\"Draw\", color=\"#BDBDBD\", linewidth=2)\n",
        "plt.axvline(0, color=\"black\", linestyle=\"--\", alpha=0.4, label=\"Equal ELO\")\n",
        "plt.xlabel(\"White ELO − Black ELO\")\n",
        "plt.ylabel(\"Predicted Probability (%)\")\n",
        "plt.title(\"Win Probability vs. ELO Difference (King's Pawn Game)\")\n",
        "plt.legend()\n",
        "plt.grid(alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"win_probability_curve.png\", dpi=150)\n",
        "plt.show()\n",
        "print(\"Win probability curve saved.\")\n",
        "\n",
        "print(\"\\n✅ All done! Saved files: eda_plots.png, training_curves.png, confusion_matrix.png, win_probability_curve.png\")"
      ],
