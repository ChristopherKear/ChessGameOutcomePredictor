      "cell_type": "code",
      "source": [
        "# 1. LOAD & EXPLORE DATA\n",
        "\n",
        "df = pd.read_csv(\"games.csv\")\n",
        "\n",
        "print(\"Shape:\", df.shape)\n",
        "print(\"\\nColumns:\", df.columns.tolist())\n",
        "print(\"\\nFirst 3 rows:\")\n",
        "print(df.head(3))\n",
        "print(\"\\nMissing values:\")\n",
        "print(df.isnull().sum())\n",
        "\n",
        "# Class distribution\n",
        "print(\"\\nOutcome distribution:\")\n",
        "print(df[\"winner\"].value_counts())\n",
        "\n",
        "fig, axes = plt.subplots(1, 3, figsize=(16, 4))\n",
        "\n",
        "# Winner distribution\n",
        "df[\"winner\"].value_counts().plot(kind=\"bar\", ax=axes[0], color=[\"#4CAF50\", \"#F44336\", \"#9E9E9E\"])\n",
        "axes[0].set_title(\"Game Outcome Distribution\")\n",
        "axes[0].set_xlabel(\"Winner\")\n",
        "axes[0].set_ylabel(\"Count\")\n",
        "axes[0].tick_params(axis=\"x\", rotation=0)\n",
        "\n",
        "# ELO distributions\n",
        "axes[1].hist(df[\"white_rating\"], bins=40, alpha=0.6, label=\"White ELO\", color=\"#90CAF9\")\n",
        "axes[1].hist(df[\"black_rating\"], bins=40, alpha=0.6, label=\"Black ELO\", color=\"#EF9A9A\")\n",
        "axes[1].set_title(\"Player ELO Distribution\")\n",
        "axes[1].set_xlabel(\"ELO Rating\")\n",
        "axes[1].set_ylabel(\"Count\")\n",
        "axes[1].legend()\n",
        "\n",
        "# ELO difference vs outcome\n",
        "df[\"elo_diff\"] = df[\"white_rating\"] - df[\"black_rating\"]\n",
        "for outcome, color in zip([\"white\", \"black\", \"draw\"], [\"#42A5F5\", \"#EF5350\", \"#BDBDBD\"]):\n",
        "    subset = df[df[\"winner\"] == outcome][\"elo_diff\"]\n",
        "    axes[2].hist(subset, bins=40, alpha=0.6, label=outcome, color=color)\n",
        "axes[2].set_title(\"ELO Difference by Outcome\")\n",
        "axes[2].set_xlabel(\"White ELO - Black ELO\")\n",
        "axes[2].set_ylabel(\"Count\")\n",
        "axes[2].legend()\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"eda_plots.png\", dpi=150)\n",
        "plt.show()\n",
        "print(\"EDA plots saved.\")"
      ],
