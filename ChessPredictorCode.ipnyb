      "cell_type": "code",
      "source": [
        "# 7. INTERACTIVE PREDICTOR\n",
        "\n",
        "def predict_outcome(white_elo, black_elo, opening_name, turns=40, rated=True, time_base=10):\n",
        "    \"\"\"\n",
        "    Predict chess game outcome probabilities.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    white_elo    : int   - White player ELO rating\n",
        "    black_elo    : int   - Black player ELO rating\n",
        "    opening_name : str   - Opening family name (e.g. \"Sicilian Defense\")\n",
        "    turns        : int   - Expected number of turns (default 40)\n",
        "    rated        : bool  - Whether the game is rated (default True)\n",
        "    time_base    : int   - Base time in minutes (default 10)\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    dict with win probabilities for white, black, and draw\n",
        "    \"\"\"\n",
        "    elo_diff = white_elo - black_elo\n",
        "\n",
        "    # Encode opening\n",
        "    opening_clean = opening_name.strip()\n",
        "    if opening_clean not in le_opening.classes_:\n",
        "        opening_clean = \"Other\"\n",
        "    opening_enc = le_opening.transform([opening_clean])[0]\n",
        "\n",
        "    features = np.array([[\n",
        "        white_elo, black_elo, elo_diff,\n",
        "        turns, int(rated), time_base, opening_enc\n",
        "    ]])\n",
        "    features_scaled = scaler.transform(features)\n",
        "    probs = improved.predict(features_scaled, verbose=0)[0]\n",
        "    result = {\n",
        "        \"Black wins\":  round(float(probs[0]) * 100, 1),\n",
        "        \"Draw\":        round(float(probs[1]) * 100, 1),\n",
        "        \"White wins\":  round(float(probs[2]) * 100, 1),\n",
        "    }\n",
        "    return result\n",
        "\n",
        "\n",
        "# --- Example predictions ---\n",
        "print(\"\\n--- Interactive Predictor Examples ---\\n\")\n",
        "\n",
        "examples = [\n",
        "    (1800, 1200, \"Sicilian Defense\"),\n",
        "    (1500, 1500, \"King's Pawn Game\"),\n",
        "    (2200, 2100, \"Queen's Gambit\"),\n",
        "    (1000, 1800, \"French Defense\"),\n",
        "]\n",
        "\n",
        "for w, b, op in examples:\n",
        "    result = predict_outcome(w, b, op)\n",
        "    print(f\"White ELO: {w} | Black ELO: {b} | Opening: {op}\")\n",
        "    for outcome, pct in result.items():\n",
        "        bar = \"█\" * int(pct / 2)\n",
        "        print(f\"  {outcome:<12} {pct:5.1f}%  {bar}\")\n",
        "    print()"
      ],
      "metadata": {
        "id": "d9IaFGTX9Ty7",
        "colab": {
