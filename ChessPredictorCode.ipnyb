        "sns.heatmap(\n",
        "    cm, annot=True, fmt=\"d\", cmap=\"Blues\",\n",
        "    xticklabels=class_names, yticklabels=class_names\n",
        ")\n",
        "plt.title(\"Confusion Matrix - Improved DNN\")\n",
        "plt.xlabel(\"Predicted\")\n",
        "plt.ylabel(\"Actual\")\n",
