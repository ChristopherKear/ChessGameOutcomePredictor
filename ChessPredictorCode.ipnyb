        "# 6. EVALUATION - CONFUSION MATRIX & CLASSIFICATION REPORT\n",
        "\n",
        "y_pred = np.argmax(improved.predict(X_test), axis=1)\n",
        "class_names = le_target.classes_  # ['black', 'draw', 'white']\n",
        "\n",
        "# Confusion matrix\n",
        "cm = confusion_matrix(y_test, y_pred)\n",
